{
  "$schema": "https://oxc-project.github.io/oxfmt/schemas/oxfmt.json",
  "printWidth": 100,
  "quoteStyle": "double",
  "semi": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "*.ipynb",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "**/dist/**",
    "**/dist-embed/**",
    "**/build/**",
    "**/target/**",
    "**/node_modules/**",
    "site/**",
    "**/static/**",
    "**/*.min.js",
    "**/*.d.ts",
    "**/*.generated.js",
    "**/*.generated.py",
    "**/cesium/**",
    "**/jupyterlite/**",
    "apps/geolibre-desktop/public/**",
    "apps/geolibre-desktop/src/lib/whitebox-menu-catalog.ts",
    "e2e/fixtures/malformed.geojson"
  ]
}
